{
  "dependencies": {
    "playwright": "^1.57.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^25.0.1",
    "allure-playwright": "^3.4.3",
    "dotenv": "^17.3.1"
  },
  "scripts": {
    "allure": "allure generate allure-results --clean",
    "test": "playwright test",
    
    "test:main": "playwright test tests/main_page",
    "test:about": "playwright test tests/about_page",
    "test:trading": "playwright test tests/trading_page",

    "test:main:authorized": "npx playwright test tests/main_page --project=authorized",
    "test:main:unauthorized": "npx playwright test tests/main_page --project=unauthorized",
    "test:main:unregistered": "npx playwright test tests/main_page --project=unregistered",

    "test:about:authorized": "npx playwright test tests/about_page --project=authorized",
    "test:about:unauthorized": "npx playwright test tests/about_page --project=unauthorized",
    "test:about:unregistered": "npx playwright test tests/about_page --project=unregistered",


    "test:trading:authorized": "npx playwright test tests/trading_page --project=authorized",
    "test:trading:unauthorized": "npx playwright test tests/trading_page --project=unauthorized",
    "test:trading:unregistered": "npx playwright test tests/trading_page --project=unregistered"
  }
}
